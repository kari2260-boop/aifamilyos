# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/aifamily

# JWT
JWT_SECRET=change-me-to-a-random-string

# AI Model (primary - DeepSeek)
MODEL_BASE_URL=https://api.deepseek.com/v1
MODEL_API_KEY=your-deepseek-api-key
MODEL_NAME=deepseek-chat

# AI Model (fallback - Qwen)
FALLBACK_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
FALLBACK_MODEL_API_KEY=your-qwen-api-key
FALLBACK_MODEL_NAME=qwen-max

# Embedding
EMBEDDING_BASE_URL=https://api.deepseek.com/v1
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=text-embedding-v1

# Vision Model (Qwen-VL via DashScope)
VISION_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL_API_KEY=your-dashscope-api-key
VISION_MODEL_NAME=qwen-vl-plus
